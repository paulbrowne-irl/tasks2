{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "task-management",
          "region": "europe-west1",
          "pinTag": true
        }
      }
    ]
  }
}
